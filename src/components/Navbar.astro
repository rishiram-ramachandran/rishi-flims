---
import LogoFull from './icons/LogoFull.astro';

const navLinks = [
  { label: 'Work',     href: '#portfolio' },
  { label: 'About',   href: '#about' },
  { label: 'Services', href: '#services' },
  { label: 'Contact', href: '#contact' },
];
---

<!-- ============================================
     DYNAMIC ISLAND NAVBAR
     ============================================ -->

<!-- Click-outside backdrop (mobile only) -->
<div id="di-backdrop" aria-hidden="true"></div>

<nav
  id="navbar"
  class="fixed top-5 left-1/2 -translate-x-1/2 z-[1000] opacity-0 -translate-y-24 transition-all duration-500 ease-[var(--ease-out-expo)]"
  aria-label="Site navigation"
>

  <!-- ── DESKTOP PILL (≥ 768px) ─────────────────────────── -->
  <div class="hidden md:flex glass rounded-full px-6 py-3 items-center gap-8">
    <a href="#hero" class="flex items-center group" aria-label="Rishi Films Home">
      <LogoFull
        size={24}
        color="currentColor"
        class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-300"
      />
    </a>

    <ul class="flex items-center gap-6">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-300 tracking-wide"
            data-target={link.href}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <!-- ── DYNAMIC ISLAND (≤ 768px) ───────────────────────── -->
  <div class="di-island md:hidden" id="di-island">

    <!-- Collapsed Pill -->
    <div class="di-pill" id="di-pill">
      <!-- Logo -->
      <a href="#hero" class="di-logo flex items-center shrink-0" aria-label="Rishi Films Home" id="di-logo-link">
        <LogoFull
          size={20}
          color="currentColor"
          class="text-[var(--color-text)] transition-colors duration-300"
        />
      </a>

      <!-- Hamburger -->
      <button
        id="di-toggle"
        class="di-hamburger"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="di-panel"
      >
        <span class="di-bar di-bar-1"></span>
        <span class="di-bar di-bar-2"></span>
        <span class="di-bar di-bar-3"></span>
      </button>
    </div>

    <!-- Expanded Panel -->
    <div
      id="di-panel"
      class="di-panel"
      role="dialog"
      aria-label="Navigation menu"
      aria-hidden="true"
    >
      <!-- Panel Header (logo + close mirrors pill) -->
      <div class="di-panel-header">
        <a href="#hero" class="flex items-center" aria-label="Rishi Films Home">
          <LogoFull
            size={20}
            color="currentColor"
            class="text-[var(--color-text)]"
          />
        </a>
        <!-- Close button (X) shown inside panel header -->
        <button
          id="di-close"
          class="di-close-btn"
          aria-label="Close navigation menu"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="3" x2="15" y2="15"/>
            <line x1="15" y1="3" x2="3" y2="15"/>
          </svg>
        </button>
      </div>

      <!-- Nav Links -->
      <nav aria-label="Main menu">
        <ul class="di-nav-list" id="di-nav-list">
          {navLinks.map((link, i) => (
            <li class="di-nav-item" style={`--item-i: ${i};`}>
              <a
                href={link.href}
                class="di-nav-link mobile-nav-link"
                data-target={link.href}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div><!-- /di-panel -->

  </div><!-- /di-island -->

</nav>

<!-- ============================================
     STYLES
     ============================================ -->
<style>
  /* ── DESKTOP: preserve existing nav shadow ── */
  nav.visible .glass {
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    border-color: rgba(200, 169, 107, 0.1);
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  /* ============================================
     DYNAMIC ISLAND — MOBILE ONLY
     ============================================ */
  @media (max-width: 767px) {

    /* ── Island wrapper ── */
    .di-island {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ─────────────────────────────────────────
       COLLAPSED PILL
       ───────────────────────────────────────── */
    .di-pill {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 200px;
      height: 56px;
      padding: 0 18px;
      border-radius: 9999px;
      background: rgba(15, 15, 15, 0.80);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      border: 1px solid rgba(255, 255, 255, 0.063);
      box-shadow:
        0 4px 24px rgba(0, 0, 0, 0.55),
        0 1px 0 rgba(255, 255, 255, 0.04) inset;
      will-change: transform;
      transform-origin: top center;
      transition:
        transform 350ms cubic-bezier(0.34, 1.56, 0.64, 1),
        backdrop-filter 350ms ease,
        box-shadow 350ms ease;
    }

    /* Scroll-down: shrink pill slightly */
    .di-island.di-scrolled .di-pill {
      transform: scale(0.92);
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      box-shadow:
        0 8px 32px rgba(0, 0, 0, 0.7),
        0 1px 0 rgba(255, 255, 255, 0.04) inset;
    }

    /* Hide pill content when panel is open */
    .di-island.di-open .di-pill {
      pointer-events: none;
      opacity: 0;
      transform: scale(0.88);
      transition:
        opacity 200ms ease,
        transform 200ms ease;
    }

    /* ─────────────────────────────────────────
       HAMBURGER BUTTON
       ───────────────────────────────────────── */
    .di-hamburger {
      display: flex;
      flex-direction: column;
      gap: 5px;
      width: 32px;
      height: 32px;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      background: none;
      border: none;
      padding: 4px;
      border-radius: 8px;
      flex-shrink: 0;
    }

    .di-bar {
      display: block;
      width: 18px;
      height: 1.5px;
      background: var(--color-text);
      border-radius: 9999px;
      transform-origin: center;
      transition:
        transform 320ms cubic-bezier(0.34, 1.56, 0.64, 1),
        opacity 250ms ease;
    }

    /* ─────────────────────────────────────────
       EXPANDED PANEL
       ───────────────────────────────────────── */
    .di-panel {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%) scale(0.92);
      width: min(90vw, 360px);
      border-radius: 28px;
      background: rgba(12, 12, 12, 0.90);
      backdrop-filter: blur(28px);
      -webkit-backdrop-filter: blur(28px);
      border: 1px solid rgba(255, 255, 255, 0.063);
      box-shadow:
        0 16px 48px rgba(0, 0, 0, 0.7),
        0 1px 0 rgba(255, 255, 255, 0.06) inset;
      padding: 0 0 20px;
      overflow: hidden;

      /* Hidden state */
      opacity: 0;
      pointer-events: none;
      visibility: hidden;
      transform-origin: top center;
      will-change: transform, opacity;
      transition:
        opacity 320ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 380ms cubic-bezier(0.34, 1.4, 0.64, 1),
        visibility 0ms linear 380ms;
      z-index: 1;
    }

    /* Open state */
    .di-island.di-open .di-panel {
      opacity: 1;
      pointer-events: auto;
      visibility: visible;
      transform: translateX(-50%) scale(1);
      transition:
        opacity 320ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 380ms cubic-bezier(0.34, 1.4, 0.64, 1),
        visibility 0ms linear 0ms;
    }

    /* ── Panel header ── */
    .di-panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 16px 20px 12px;
      height: 56px;
    }

    /* ── Close button ── */
    .di-close-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      border: none;
      background: rgba(255, 255, 255, 0.06);
      border-radius: 50%;
      color: var(--color-text-muted);
      cursor: pointer;
      transition:
        background 250ms ease,
        color 250ms ease,
        transform 250ms ease;
    }

    .di-close-btn:hover {
      background: rgba(200, 169, 107, 0.15);
      color: var(--color-accent);
      transform: rotate(90deg);
    }

    /* ── Nav list ── */
    .di-nav-list {
      list-style: none;
      padding: 4px 12px;
      margin: 0;
    }

    .di-nav-item {
      opacity: 0;
      transform: translateY(8px);
      transition:
        opacity 280ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 280ms cubic-bezier(0.16, 1, 0.3, 1);
      transition-delay: calc(var(--item-i, 0) * 40ms);
    }

    /* Stagger in when open */
    .di-island.di-open .di-nav-item {
      opacity: 1;
      transform: translateY(0);
    }

    /* Stagger out — faster, no delay */
    .di-island:not(.di-open) .di-nav-item {
      transition-delay: 0ms;
    }

    .di-nav-link {
      display: flex;
      align-items: center;
      min-height: 48px;
      padding: 0 12px;
      border-radius: 12px;
      font-family: var(--font-body);
      font-size: 1rem;
      font-weight: 500;
      color: var(--color-text-muted);
      text-decoration: none;
      letter-spacing: 0.01em;
      transition:
        background 200ms ease,
        color 200ms ease,
        transform 150ms ease;
    }

    .di-nav-link:hover,
    .di-nav-link:focus-visible {
      background: rgba(255, 255, 255, 0.05);
      color: var(--color-text);
    }

    .di-nav-link:active {
      transform: scale(0.97);
      background: rgba(200, 169, 107, 0.08);
      color: var(--color-accent);
    }

    .di-nav-link.active {
      color: var(--color-accent);
    }



    /* ────────────────────────────────────────────
       BACKDROP
       ──────────────────────────────────────────── */
    #di-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 999;
      background: transparent;
    }

    #di-backdrop.active {
      display: block;
    }

    /* ────────────────────────────────────────────
       REDUCED MOTION
       ──────────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .di-pill,
      .di-panel,
      .di-nav-item,
      .di-bar,
      .di-close-btn {
        transition: none !important;
        transition-delay: 0ms !important;
      }
    }

  }/* end @media mobile */
</style>

<!-- ============================================
     SCRIPT
     ============================================ -->
<script>
  (function () {

    /* ── Element refs ── */
    const navbar    = document.getElementById('navbar')      as HTMLElement | null;
    const island    = document.getElementById('di-island')   as HTMLElement | null;
    const toggle    = document.getElementById('di-toggle')   as HTMLButtonElement | null;
    const closeBtn  = document.getElementById('di-close')    as HTMLButtonElement | null;
    const panel     = document.getElementById('di-panel')    as HTMLElement | null;
    const backdrop  = document.getElementById('di-backdrop') as HTMLElement | null;
    const navLinks  = document.querySelectorAll<HTMLElement>('.nav-link');
    const mobileNavLinks = document.querySelectorAll<HTMLElement>('.mobile-nav-link');

    /* ── State ── */
    let isOpen = false;
    let lastScrollY = window.scrollY;
    let scrollingDown = false;

    /* ═══════════════════════════════════════════
       OPEN / CLOSE
       ═══════════════════════════════════════════ */
    function openMenu() {
      if (!island || !panel || !backdrop || !toggle) return;
      isOpen = true;

      island.classList.add('di-open');
      backdrop.classList.add('active');
      document.body.style.overflow = 'hidden';

      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close navigation menu');
      panel.setAttribute('aria-hidden', 'false');

      /* Move focus into panel after transition */
      setTimeout(() => {
        const firstFocusable = panel.querySelector<HTMLElement>('a, button');
        firstFocusable?.focus();
      }, 80);
    }

    function closeMenu() {
      if (!island || !panel || !backdrop || !toggle) return;
      isOpen = false;

      island.classList.remove('di-open');
      backdrop.classList.remove('active');
      document.body.style.overflow = '';

      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open navigation menu');
      panel.setAttribute('aria-hidden', 'true');

      toggle.focus();
    }

    /* ═══════════════════════════════════════════
       FOCUS TRAP
       ═══════════════════════════════════════════ */
    function trapFocus(e: KeyboardEvent) {
      if (!isOpen || !panel) return;
      const focusable = Array.from(
        panel.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      );
      if (focusable.length === 0) return;

      const first = focusable[0];
      const last  = focusable[focusable.length - 1];

      if (e.key === 'Tab') {
        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      }

      if (e.key === 'Escape') {
        e.preventDefault();
        closeMenu();
      }
    }

    /* ═══════════════════════════════════════════
       SCROLL — visibility + shrink effect
       ═══════════════════════════════════════════ */
    function handleScroll() {
      const currentScroll = window.scrollY;
      scrollingDown = currentScroll > lastScrollY;
      lastScrollY = currentScroll;

      /* Navbar visibility (existing logic preserved) */
      if (currentScroll > 80) {
        navbar?.classList.add('visible', 'opacity-100', 'translate-y-0');
        navbar?.classList.remove('opacity-0', '-translate-y-24');
      } else {
        navbar?.classList.remove('visible', 'opacity-100', 'translate-y-0');
        navbar?.classList.add('opacity-0', '-translate-y-24');
        /* Auto-close when scrolled to top */
        if (isOpen) closeMenu();
      }

      /* Dynamic Island scroll shrink (mobile) */
      if (island) {
        if (scrollingDown && currentScroll > 120) {
          island.classList.add('di-scrolled');
        } else if (!scrollingDown) {
          island.classList.remove('di-scrolled');
        }
      }
    }

    /* ═══════════════════════════════════════════
       SCROLL SPY (desktop nav links)
       ═══════════════════════════════════════════ */
    function handleScrollSpy() {
      const sections = document.querySelectorAll<HTMLElement>('section[id]');
      let current = '';
      const scrollPos = window.scrollY + 150;

      sections.forEach((section) => {
        const sectionTop    = section.offsetTop;
        const sectionHeight = section.offsetHeight;
        const id = section.getAttribute('id');
        if (scrollPos >= sectionTop && scrollPos < sectionTop + sectionHeight && id) {
          current = id;
        }
      });

      navLinks.forEach((link) => {
        link.classList.remove('active');
        const target = link.getAttribute('data-target');
        if (target === `#${current}`) link.classList.add('active');
      });
    }

    /* ═══════════════════════════════════════════
       SMOOTH SCROLL (all anchor links)
       ═══════════════════════════════════════════ */
    function initSmoothScroll() {
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const href = this.getAttribute('href');
          if (href && href !== '#') {
            const target = document.querySelector(href);
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
          /* Also close mobile menu on link click */
          if (isOpen) closeMenu();
        });
      });
    }

    /* ═══════════════════════════════════════════
       EVENT LISTENERS
       ═══════════════════════════════════════════ */

    /* Toggle button */
    toggle?.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    /* Close button inside panel */
    closeBtn?.addEventListener('click', closeMenu);

    /* Click outside (backdrop) */
    backdrop?.addEventListener('click', closeMenu);

    /* Mobile nav link clicks */
    mobileNavLinks.forEach((link) => {
      link.addEventListener('click', () => {
        if (isOpen) closeMenu();
      });
    });

    /* Keyboard */
    document.addEventListener('keydown', trapFocus);

    /* Scroll */
    window.addEventListener('scroll', handleScroll,     { passive: true });
    window.addEventListener('scroll', handleScrollSpy,  { passive: true });

    /* Init */
    handleScroll();
    initSmoothScroll();

  })();
</script>

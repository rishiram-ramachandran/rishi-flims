---
export interface Props {
  category: {
    id: string;
    title: string;
    videos: Array<{
      id: string;
      platform: "instagram" | "youtube";
      url: string;
      label?: string;
    }>;
  };
}

const { category } = Astro.props;

// Helper function to convert YouTube share URL to thumbnail URL
const getYouTubeThumbnail = (url: string): string => {
  const shortUrlMatch = url.match(/youtube\.com\/shorts\/([\w-]+)/);
  const regularMatch = url.match(
    /(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/,
  );
  const videoId = shortUrlMatch?.[1] || regularMatch?.[1];
  return videoId ? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg` : "";
};

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith("/") ? base : `${base}/`;
---

<div class="carousel-section fade-in">
  <div class="carousel-header">
    <h3 class="carousel-title">{category.title}</h3>
    <div class="swiper-nav-buttons">
      <button
        class="swiper-button-prev"
        id={`prev-${category.id}`}
        aria-label="Previous slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="nav-icon"
        >
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        class="swiper-button-next"
        id={`next-${category.id}`}
        aria-label="Next slide"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="nav-icon"
        >
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>

  <div class="carousel-wrapper">
    <div class="swiper swiper-container" data-category-id={category.id}>
      <div class="swiper-wrapper">
        {
          category.videos.map((video) => (
            <div
              class="swiper-slide video-card"
              data-video-id={video.id}
              data-platform={video.platform}
              data-url={video.url}
            >
              <div class="video-card-inner">
                {video.platform === "instagram" ? (
                  <img
                    src={`${baseUrl}images/thumbnails/${video.id}.jpg`}
                    alt={
                      video.label
                        ? `Rishi Films - ${video.label} Promotional Video Reel`
                        : "Rishi Films - Videography and Video Editing Reel"
                    }
                    class="video-thumbnail"
                    loading="lazy"
                  />
                ) : video.platform === "youtube" ? (
                  <img
                    src={getYouTubeThumbnail(video.url)}
                    alt={
                      video.label
                        ? `Rishi Films - ${video.label} Video Reel`
                        : "Rishi Films - YouTube Video Reel"
                    }
                    class="video-thumbnail"
                    loading="lazy"
                  />
                ) : null}

                <div class="play-button-overlay">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <polygon points="5 3 19 12 5 21 5 3" fill="currentColor" />
                  </svg>
                </div>

                <div class="card-gradient-overlay" />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  import Swiper from "swiper";
  import { Navigation, FreeMode, Mousewheel, Autoplay } from "swiper/modules";
  import "swiper/css";
  import "swiper/css/navigation";

  // Keep track of all Swiper instances to control autoplay globally
  const swiperInstances: Swiper[] = [];

  // Initialize Swiper for each video category carousel
  document.querySelectorAll(".swiper-container").forEach((container) => {
    const categoryId = container.getAttribute("data-category-id");
    if (!categoryId) return;

    const swiper = new Swiper(container as HTMLElement, {
      modules: [Navigation, FreeMode, Mousewheel, Autoplay],
      slidesPerView: 1.2,
      spaceBetween: 12,
      grabCursor: true,
      freeMode: {
        enabled: true,
        sticky: true,
        momentum: true,
        momentumRatio: 0.85,
        momentumVelocityRatio: 0.85,
      },
      mousewheel: {
        forceToAxis: true,
      },
      touchEventsTarget: "container",
      touchStartForce: true,
      autoplay: {
        delay: 3000, // Snappy, enterprise-standard delay (3s)
        disableOnInteraction: false, // Don't disable autoplay after user interactions
        pauseOnMouseEnter: true, // Pause autoplay when mouse enters the carousel
      },
      speed: 700, // Snappy transition speed (0.7s) like Netflix/Prime Video
      navigation: {
        nextEl: `#next-${categoryId}`,
        prevEl: `#prev-${categoryId}`,
      },
      breakpoints: {
        320: {
          slidesPerView: 1.1,
          spaceBetween: 10,
        },
        375: {
          slidesPerView: 1.2,
          spaceBetween: 12,
        },
        480: {
          slidesPerView: 1.5,
          spaceBetween: 14,
        },
        768: {
          slidesPerView: 2.2,
          spaceBetween: 20,
        },
        1024: {
          slidesPerView: 3.5,
          spaceBetween: 24,
        },
        1440: {
          slidesPerView: 4.8,
          spaceBetween: 24,
        },
      },
    });

    swiperInstances.push(swiper);
  });

  // Observe the body class to pause autoplay when the lightbox modal is open
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (
        mutation.type === "attributes" &&
        mutation.attributeName === "class"
      ) {
        const isLightboxOpen =
          document.body.classList.contains("lightbox-open");
        swiperInstances.forEach((swiper) => {
          if (isLightboxOpen) {
            swiper.autoplay.stop();
          } else {
            swiper.autoplay.start();
          }
        });
      }
    });
  });

  observer.observe(document.body, {
    attributes: true,
    attributeFilter: ["class"],
  });
</script>

<style>
  .carousel-section {
    margin-bottom: 4rem;
    position: relative;
  }

  .carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .carousel-title {
    font-size: 1.5rem;
    margin: 0;
    color: var(--color-light);
  }

  .carousel-wrapper {
    position: relative;
    width: 100%;
  }

  .swiper-nav-buttons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .swiper-button-next,
  .swiper-button-prev {
    position: relative;
    top: auto;
    bottom: auto;
    left: auto;
    right: auto;
    margin: 0;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 50%;
    color: var(--color-accent);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 5;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .swiper-button-next::after,
  .swiper-button-prev::after {
    display: none; /* Hide default Swiper font icon */
  }

  .nav-icon {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .swiper-button-next:hover,
  .swiper-button-prev:hover {
    background: var(--color-accent);
    color: var(--color-dark);
    border-color: var(--color-accent);
    box-shadow: 0 0 15px rgba(212, 165, 116, 0.35);
    transform: scale(1.08);
  }

  .swiper-button-prev:hover .nav-icon {
    transform: translateX(-1px);
  }

  .swiper-button-next:hover .nav-icon {
    transform: translateX(1px);
  }

  .swiper-button-disabled {
    opacity: 0.25;
    cursor: not-allowed;
    pointer-events: none;
    border-color: var(--color-border);
    background: rgba(255, 255, 255, 0.01);
    color: var(--color-text-secondary);
    box-shadow: none;
    transform: none !important;
  }

  .swiper-container {
    width: 100%;
    overflow: hidden;
    padding: 0.5rem 0;
  }

  .video-card {
    aspect-ratio: 9 / 16;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    background: var(--color-darker);
    border: 1px solid var(--color-border);
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .video-card:hover {
    transform: scale(1.02);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px rgba(212, 165, 116, 0.15);
  }

  .video-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #000;
  }

  .video-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .video-card:hover .video-thumbnail {
    transform: scale(1.05);
  }

  .play-button-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(10, 10, 10, 0.65);
    backdrop-filter: blur(4px);
    border: 2px solid rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-light);
    transition: all 0.3s ease;
    z-index: 5;
  }

  .play-button-overlay svg {
    width: 20px;
    height: 20px;
    margin-left: 3px;
    transition: transform 0.3s ease;
  }

  .video-card:hover .play-button-overlay {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-dark);
    box-shadow: 0 0 20px rgba(212, 165, 116, 0.4);
  }

  .video-card:hover .play-button-overlay svg {
    transform: scale(1.1);
  }

  .card-gradient-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 35%;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.8) 0%,
      rgba(0, 0, 0, 0) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  @media (max-width: 1024px) {
    .carousel-title {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 768px) {
    .carousel-header {
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .carousel-title {
      font-size: 1.1rem;
    }

    .swiper-button-prev,
    .swiper-button-next {
      width: 40px;
      height: 40px;
      min-width: 40px;
      min-height: 40px;
      flex-shrink: 0;
    }

    .nav-icon {
      width: 16px;
      height: 16px;
    }

    .swiper-nav-buttons {
      gap: 0.5rem;
    }
  }

  @media (max-width: 480px) {
    .carousel-section {
      margin-bottom: 2.5rem;
    }

    .carousel-header {
      flex-wrap: wrap;
      gap: 0.75rem;
    }

    .carousel-title {
      font-size: 1rem;
      width: 100%;
    }

    .swiper-button-prev,
    .swiper-button-next {
      width: 36px;
      height: 36px;
      min-width: 36px;
      min-height: 36px;
    }

    .nav-icon {
      width: 14px;
      height: 14px;
    }

    .video-card {
      border-radius: 8px;
    }

    .play-button-overlay {
      width: 48px;
      height: 48px;
    }

    .play-button-overlay svg {
      width: 16px;
      height: 16px;
    }

    .card-gradient-overlay {
      height: 30%;
    }
  }

  @media (max-width: 320px) {
    .carousel-section {
      margin-bottom: 2rem;
    }

    .carousel-title {
      font-size: 0.95rem;
    }

    .swiper-button-prev,
    .swiper-button-next {
      width: 34px;
      height: 34px;
      min-width: 34px;
      min-height: 34px;
    }

    .play-button-overlay {
      width: 44px;
      height: 44px;
    }

    .play-button-overlay svg {
      width: 14px;
      height: 14px;
    }
  }
</style>

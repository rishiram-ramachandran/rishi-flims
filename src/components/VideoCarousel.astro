---
export interface Props {
  category: {
    id: string;
    title: string;
    videos: Array<{
      id: string;
      platform: "instagram" | "youtube";
      url: string;
      label?: string;
    }>;
  };
}

const { category } = Astro.props;

const getYouTubeThumbnail = (url: string): string => {
  const shortUrlMatch = url.match(/youtube\.com\/shorts\/([\w-]+)/);
  const regularMatch = url.match(
    /(?:youtube\.com\/watch\?v=|youtu\.be\/)([\w-]+)/,
  );
  const videoId = shortUrlMatch?.[1] || regularMatch?.[1];
  return videoId ? `https://img.youtube.com/vi/${videoId}/hqdefault.jpg` : "";
};

const base = import.meta.env.BASE_URL;
const baseUrl = base.endsWith("/") ? base : `${base}/`;
---

<div class="carousel-section" data-reveal="fade-up">
  <div class="flex items-end justify-between mb-6">
    <div>
      <h3 class="font-display text-xl md:text-2xl lg:text-3xl tracking-wide text-[var(--color-text)]" data-reveal="fade-left">
        {category.title}
      </h3>
      <p class="text-[var(--color-text-muted)] text-xs mt-1">
        <span class="video-count" data-count={category.videos.length}>0</span> {category.videos.length === 1 ? 'video' : 'videos'}
      </p>
    </div>

    <!-- Desktop arrows -->
    <div class="hidden md:flex items-center gap-2">
      <button
        class="carousel-prev w-9 h-9 rounded-full border border-[var(--color-border-light)] bg-[var(--color-bg-secondary)]/60 flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-all duration-300"
        data-target={category.id}
        aria-label="Previous"
        data-cursor-grow
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
      <button
        class="carousel-next w-9 h-9 rounded-full border border-[var(--color-border-light)] bg-[var(--color-bg-secondary)]/60 flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-all duration-300"
        data-target={category.id}
        aria-label="Next"
        data-cursor-grow
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="relative -mx-6 md:-mx-12 lg:-mx-20 px-6 md:px-12 lg:px-20">
    <div
      class="carousel-track"
      id={`track-${category.id}`}
      data-category-id={category.id}
    >
      {category.videos.map((video, i) => (
        <div
          class="carousel-item video-card flex-shrink-0 w-[260px] md:w-[280px] lg:w-[300px]"
          data-video-id={video.id}
          data-platform={video.platform}
          data-url={video.url}
          data-cursor-play
          style={`--delay: ${i * 50}ms;`}
        >
          <div class="video-card-inner relative aspect-[9/16] rounded-2xl overflow-hidden bg-[var(--color-bg-secondary)] border border-[var(--color-border)] cursor-pointer group transition-all duration-500 hover:border-[var(--color-accent)]/25 hover:shadow-[0_16px_48px_-12px_rgba(200,169,107,0.12)] hover:scale-[1.02]">
            {video.platform === "instagram" ? (
              <img
                src={`${baseUrl}images/thumbnails/${video.id}.jpg`}
                alt={video.label ? `Rishi Films - ${video.label}` : "Rishi Films Reel"}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                style="object-position: center;"
              />
            ) : video.platform === "youtube" ? (
              <img
                src={getYouTubeThumbnail(video.url)}
                alt={video.label ? `Rishi Films - ${video.label}` : "Rishi Films YouTube"}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                loading="lazy"
                style="object-position: center;"
              />
            ) : null}

            <!-- Label badge -->
            {video.label && (
              <div class="absolute top-3 left-3 z-10">
                <span class="px-2.5 py-1 rounded-full bg-[var(--color-bg)]/80 backdrop-blur-md text-[var(--color-accent)] text-[10px] font-semibold tracking-wide border border-[var(--color-border-light)]">
                  {video.label}
                </span>
              </div>
            )}

            <!-- Play button -->
            <div class="absolute inset-0 flex items-center justify-center z-10">
              <div class="play-btn w-12 h-12 rounded-full bg-[var(--color-bg)]/60 backdrop-blur-md border border-white/10 flex items-center justify-center text-white transition-all duration-500 group-hover:bg-[var(--color-accent)] group-hover:text-[var(--color-bg)] group-hover:scale-110 group-hover:border-[var(--color-accent)]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                  <polygon points="8 5 19 12 8 19"/>
                </svg>
              </div>
            </div>

            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/50 via-transparent to-transparent pointer-events-none"></div>

            <!-- Border tracing animation -->
            <div class="border-trace absolute inset-0 rounded-2xl pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .video-card-inner {
    will-change: transform, box-shadow;
  }

  .play-btn {
    will-change: transform, background-color;
  }

  .border-trace::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid transparent;
    border-radius: inherit;
    background: linear-gradient(90deg, var(--color-accent), transparent) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: border-spin 0.8s linear forwards;
  }

  @keyframes border-spin {
    from {
      background: linear-gradient(0deg, var(--color-accent), transparent 30%) border-box;
    }
    to {
      background: linear-gradient(360deg, var(--color-accent), transparent 30%) border-box;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  (function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Count up animation for video counts
    const countElements = document.querySelectorAll('.video-count');
    countElements.forEach((el) => {
      const target = parseInt(el.getAttribute('data-count') || '0', 10);
      let counted = false;

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !counted) {
            counted = true;

            if (prefersReducedMotion) {
              el.textContent = String(target);
            } else {
              const duration = 800;
              const start = performance.now();
              const step = (now: number) => {
                const progress = Math.min((now - start) / duration, 1);
                el.textContent = String(Math.round(progress * target));
                if (progress < 1) requestAnimationFrame(step);
              };
              requestAnimationFrame(step);
            }

            observer.disconnect();
          }
        });
      }, { threshold: 0.5 });

      observer.observe(el);
    });

    // Carousel fade-in animation
    const carousels = document.querySelectorAll('.carousel-section');
    carousels.forEach((carousel) => {
      if (!prefersReducedMotion) {
        gsap.fromTo(carousel,
          { opacity: 0, y: 30 },
          {
            opacity: 1,
            y: 0,
            duration: 0.6,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: carousel,
              start: 'top 90%',
              toggleActions: 'play none none none'
            }
          }
        );
      }
    });

    // Detect and optimize landscape ratio thumbnails
    const adjustLandscapeThumbnails = () => {
      const cards = document.querySelectorAll('.video-card-inner');
      cards.forEach((card) => {
        const img = card.querySelector('img');
        if (!img) return;

        const checkDimensions = () => {
          const ratio = img.naturalWidth / img.naturalHeight;
          if (ratio > 1.2) {
            img.style.objectFit = 'cover';
            img.style.objectPosition = 'center';
            img.classList.add('landscape-cropped');
          }
        };

        if (img.complete) {
          checkDimensions();
        } else {
          img.addEventListener('load', checkDimensions);
        }
      });
    };

    adjustLandscapeThumbnails();

    // Navigation buttons
    document.querySelectorAll('.carousel-prev, .carousel-next').forEach((btn) => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const track = document.getElementById(`track-${targetId}`);
        if (!track) return;

        const isNext = btn.classList.contains('carousel-next');
        const cardWidth = track.querySelector('.carousel-item')?.clientWidth || 280;
        const gap = 16;
        const scrollAmount = cardWidth + gap;

        track.scrollBy({
          left: isNext ? scrollAmount : -scrollAmount,
          behavior: 'smooth'
        });
      });
    });

    // Open lightbox on card click
    document.querySelectorAll('.video-card').forEach((card) => {
      card.addEventListener('click', () => {
        const platform = card.getAttribute('data-platform');
        const url = card.getAttribute('data-url');
        if (platform && url) {
          window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { platform, url } }));
        }
      });
    });
  })();
</script>

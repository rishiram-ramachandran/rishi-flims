---
import siteData from '../data/site.json';

const { profileImage } = siteData;
---

<section id="about" class="relative py-32 md:py-40 lg:py-48 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Image -->
      <div class="animate-on-scroll fade-left">
        <div class="relative aspect-[3/4] max-w-lg mx-auto lg:mx-0 overflow-hidden rounded-3xl">
          <img
            src={profileImage}
            alt="Rishiram - Videographer & Video Editor"
            class="w-full h-full object-cover"
            loading="lazy"
            width="600"
            height="800"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)]/40 to-transparent"></div>
        </div>
      </div>

      <!-- Content -->
      <div class="animate-on-scroll fade-right">
        <p class="text-[var(--color-accent)] text-sm font-semibold tracking-[0.2em] uppercase mb-4">About</p>
        <h2 class="font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.9] tracking-wide text-[var(--color-text)] mb-8">
          ONE-MAN CREW,<br/>FULL-SERVICE OUTPUT
        </h2>
        <div class="space-y-6 text-[var(--color-text-muted)] text-base md:text-lg leading-relaxed max-w-xl">
          <p>
            I'm Rishiram, a videographer and video editor based in Tamil Nadu. I help business owners turn their products and moments into cinematic content — I shoot it, I edit it, I deliver it.
          </p>
          <p>
            I've collaborated with brands like <span class="text-[var(--color-text)]">TVS</span>, <span class="text-[var(--color-text)]">TVS Racing</span>, <span class="text-[var(--color-text)]">Oppo India</span>, <span class="text-[var(--color-text)]">Vivo</span>, and <span class="text-[var(--color-text)]">Insta360</span>, creating promotional content that's been featured and pushed live on their own channels.
          </p>
          <p>
            One-man crew, full-service output: concept to final cut.
          </p>
        </div>

        <div class="mt-10 pt-8 border-t border-[var(--color-border)]">
          <p class="text-[var(--color-accent)] text-sm font-medium tracking-wide">
            Edited on DaVinci Resolve
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

---
const services = [
  {
    num: "01",
    title: "BUSINESS VIDEOGRAPHY",
    tag: "On-location shoots",
    desc: "On-location shoots for business owners: products, spaces, processes, people.",
    icon: `<svg aria-hidden="true" role="img" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
  },
  {
    num: "02",
    title: "VIDEO EDITING",
    tag: "Color & sound",
    desc: "Color grading, sound design, pacing — turning raw footage into a finished story.",
    icon: `<svg aria-hidden="true" role="img" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>`,
  },
  {
    num: "03",
    title: "BRAND PROMOTIONS",
    tag: "End-to-end marketing",
    desc: "End-to-end influencer marketing — concept, shoot, edit, and publish promotional content on my own platform for brands like TVS, Oppo, Vivo, and Insta360.",
    icon: `<svg aria-hidden="true" role="img" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
  },
  {
    num: "04",
    title: "CINEMATIC STORYTELLING",
    tag: "Narrative films",
    desc: "Narrative-driven short films and reels that captivate and convert.",
    icon: `<svg aria-hidden="true" role="img" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 7.8l-7.7 4.4-7.7-4.4"/><path d="M3 17.5V6.5l9 5.1 9-5.1v11l-9 5.1-9-5.1z"/></svg>`,
  },
  {
    num: "05",
    title: "TALKING HEAD CONTENT",
    tag: "Presenter videos",
    desc: "Clean, professional presenter-style videos for founders, creators, and brands.",
    icon: `<svg aria-hidden="true" role="img" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v12a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
];

const stats = [
  { number: 194, suffix: "K+", label: "Instagram Followers" },
  { number: 5, suffix: "+", label: "Brand Collaborations" },
  { number: 3, suffix: "+", label: "Years Experience" },
  { number: 48, suffix: "HR", label: "Avg Turnaround Time" },
];
---

<section id="services" class="py-16 md:py-20 lg:py-24">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-10 md:mb-14 animate-on-scroll">
      <p class="text-[var(--color-accent)] text-xs font-semibold tracking-[0.2em] uppercase mb-3">Services</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[0.9] tracking-wide text-[var(--color-text)]">
        WHAT I DO
      </h2>
    </div>

    <!-- Accordion list -->
    <div class="services-accordion" role="region" aria-label="Services list">
      {services.map((s) => (
        <div class="service-row group" data-service={s.num}>
          <!-- Hairline top border -->
          <div class="absolute top-0 left-0 right-0 h-px bg-[var(--color-accent)]/15"></div>

          <!-- Trigger row -->
          <button
            class="service-trigger w-full flex items-center gap-4 md:gap-6 py-5 md:py-6 text-left cursor-pointer relative z-10"
            aria-expanded="false"
            aria-controls={`service-panel-${s.num}`}
          >
            <!-- Index number -->
            <span class="flex-shrink-0 font-mono text-xs text-[var(--color-accent)] tracking-wider w-8 md:w-10">
              {s.num}
            </span>

            <!-- Title -->
            <span class="service-title flex-1 font-display text-[clamp(1.5rem,3.5vw,3.2rem)] tracking-wide text-[var(--color-text)] uppercase transition-transform duration-500 ease-[var(--ease-out-expo)]">
              {s.title}
            </span>

            <!-- Tag (desktop only) -->
            <span class="hidden lg:block flex-shrink-0 text-xs text-[var(--color-text-muted)] tracking-wide uppercase">
              {s.tag}
            </span>

            <!-- Chevron -->
            <span class="service-chevron flex-shrink-0 text-[var(--color-text-muted)] transition-transform duration-400 ease-[var(--ease-out-expo)]">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 6l4 4 4-4"/></svg>
            </span>
          </button>

          <!-- Expandable panel -->
          <div
            id={`service-panel-${s.num}`}
            class="service-panel grid transition-all duration-500 ease-[var(--ease-out-expo)]"
            style="grid-template-rows: 0fr; opacity: 0;"
            aria-hidden="true"
          >
            <div class="overflow-hidden">
              <div class="flex items-start gap-4 md:gap-6 pb-6 md:pb-8 pl-8 md:pl-[3.25rem]">
                <div class="flex-1 max-w-xl">
                  <p class="text-[var(--color-text-muted)] text-sm md:text-[0.95rem] leading-relaxed">
                    {s.desc}
                  </p>
                </div>
                <div class="hidden md:flex flex-shrink-0 w-12 h-12 items-center justify-center text-[var(--color-accent)]/60">
                  <Fragment set:html={s.icon} />
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
      <!-- Bottom hairline -->
      <div class="h-px bg-[var(--color-accent)]/15"></div>
    </div>

    <!-- Stats bar -->
    <div class="stat-bar mt-12 md:mt-16 animate-on-scroll scale-in opacity-0">
      <div class="relative border-t border-b border-[var(--color-accent)]/10 bg-[#0E0E0E]">
        <div class="grid grid-cols-2 md:grid-cols-4">
          {stats.map((stat, i) => (
            <div class={`stat-item relative p-6 md:p-8 text-center ${i < stats.length - 1 ? 'md:after:content-[""] md:after:absolute md:after:right-0 md:after:top-1/4 md:after:h-1/2 md:after:w-px md:after:bg-[var(--color-accent)]/20' : ''}`}>
              <div class="stat-number font-display text-[clamp(2rem,4vw,3.5rem)] leading-none text-[var(--color-accent)] mb-1" data-target={stat.number} data-suffix={stat.suffix}>
                0{stat.suffix}
              </div>
              <div class="text-[0.65rem] uppercase tracking-[0.15em] text-[var(--color-text-muted)]/80">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .service-row {
    position: relative;
    transition: background-color 0.4s ease;
  }
  .service-row:hover,
  .service-row.is-open {
    background-color: rgba(200, 169, 107, 0.04);
  }
  .service-row.is-open .service-title {
    transform: translateX(12px);
  }
  .service-row.is-open .service-chevron {
    transform: rotate(180deg);
  }
  .service-row.is-open .service-panel {
    grid-template-rows: 1fr !important;
    opacity: 1 !important;
  }
  .service-trigger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
</style>

<script>
  (function() {
    // Accordion
    const rows = document.querySelectorAll('.service-row');
    rows.forEach((row) => {
      const trigger = row.querySelector('.service-trigger');
      if (!trigger) return;

      const toggle = () => {
        const isOpen = row.classList.contains('is-open');
        // Close all
        rows.forEach((r) => {
          r.classList.remove('is-open');
          const btn = r.querySelector('.service-trigger');
          const panel = r.querySelector('.service-panel');
          if (btn) btn.setAttribute('aria-expanded', 'false');
          if (panel) {
            panel.setAttribute('aria-hidden', 'true');
            (panel as HTMLElement).style.gridTemplateRows = '0fr';
            (panel as HTMLElement).style.opacity = '0';
          }
        });
        // Open this one if it was closed
        if (!isOpen) {
          row.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
          const panel = row.querySelector('.service-panel');
          if (panel) {
            panel.setAttribute('aria-hidden', 'false');
            (panel as HTMLElement).style.gridTemplateRows = '1fr';
            (panel as HTMLElement).style.opacity = '1';
          }
        }
      };

      trigger.addEventListener('click', toggle);
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle();
        }
      });
    });

    // CountUp + stat bar reveal
    const statBar = document.querySelector('.stat-bar');
    const statNumbers = document.querySelectorAll('.stat-number');
    let counted = false;

    const easeOutExpo = (t: number) => (t === 1 ? 1 : 1 - Math.pow(2, -10 * t));

    const countUp = (el: HTMLElement, target: number, suffix: string, duration = 1500) => {
      const start = performance.now();
      const step = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = easeOutExpo(progress);
        const current = Math.round(eased * target);
        el.textContent = current + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !counted) {
          counted = true;
          // Reveal bar
          statBar?.classList.add('visible');
          // Animate numbers
          statNumbers.forEach((el) => {
            const target = parseInt(el.getAttribute('data-target') || '0', 10);
            const suffix = el.getAttribute('data-suffix') || '';
            countUp(el as HTMLElement, target, suffix);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });

    if (statBar) observer.observe(statBar);
  })();
</script>

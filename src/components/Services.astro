---
const services = [
  {
    title: "Business Videography",
    desc: "On-location shoots for products, spaces, processes, and people.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
  },
  {
    title: "Video Editing",
    desc: "Color grading, sound design, pacing — raw footage becomes a finished story.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>`,
  },
  {
    title: "Brand Promotions",
    desc: "End-to-end influencer marketing — concept, shoot, edit, and publish.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l18-5v12L3 14v-3z"/><path d="M11.6 16.8a3 3 0 1 1-5.8-1.6"/></svg>`,
  },
  {
    title: "Cinematic Storytelling",
    desc: "Narrative-driven short films and reels that captivate and convert.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.2 7.8l-7.7 4.4-7.7-4.4"/><path d="M3 17.5V6.5l9 5.1 9-5.1v11l-9 5.1-9-5.1z"/></svg>`,
  },
  {
    title: "Talking Head Content",
    desc: "Professional presenter-style videos for founders and creators.",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v12a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
  },
];

const stats = [
  { number: 194, suffix: "K+", label: "Instagram Followers" },
  { number: 40, suffix: "+", label: "Brand Collabs" },
  { number: 3, suffix: "+", label: "Years Experience" },
  { number: 48, suffix: "HR", label: "Avg Turnaround" },
];
---

<section id="services" class="py-16 md:py-20 lg:py-24">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-10 md:mb-14" data-reveal="fade-up">
      <p class="text-[var(--color-accent)] text-xs font-semibold tracking-[0.2em] uppercase mb-3">Services</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[0.9] tracking-wide text-[var(--color-text)]">
        WHAT I DO
      </h2>
    </div>

    <!-- Premium Service Cards Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5" data-reveal-stagger>
      {services.map((s, i) => (
        <div
          class="service-card group relative p-6 md:p-7 rounded-2xl bg-[var(--color-bg-secondary)]/60 border border-[var(--color-border)] backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:border-[var(--color-accent)]/25 hover:shadow-[0_16px_48px_-12px_rgba(200,169,107,0.12)]"
          data-reveal="fade-up"
          data-cursor-grow
        >
          <!-- Gradient overlay on hover -->
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-[var(--color-accent)]/[0.04] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

          <!-- Icon -->
          <div class="relative z-10 w-11 h-11 rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] mb-4 transition-transform duration-300 group-hover:scale-105">
            <Fragment set:html={s.icon} />
          </div>

          <!-- Title -->
          <h3 class="relative z-10 font-display text-lg md:text-xl tracking-wide text-[var(--color-text)] uppercase mb-2">
            {s.title}
          </h3>

          <!-- Description -->
          <p class="relative z-10 text-[var(--color-text-muted)] text-sm leading-relaxed">
            {s.desc}
          </p>

          <!-- Border animation element -->
          <div class="absolute inset-0 rounded-2xl border-2 border-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style="border-image: linear-gradient(135deg, var(--color-accent), transparent) 1;"></div>
        </div>
      ))}
    </div>

    <!-- Stats bar -->
    <div class="stat-bar mt-12 md:mt-16" data-reveal="fade-up">
      <div class="relative border-t border-b border-[var(--color-accent)]/10 bg-[var(--color-bg-secondary)]/30 rounded-xl overflow-hidden">
        <div class="grid grid-cols-2 md:grid-cols-4">
          {stats.map((stat, i) => (
            <div class={`stat-item relative p-5 md:p-6 text-center ${i < stats.length - 1 ? 'md:after:content-[""] md:after:absolute md:after:right-0 md:after:top-1/4 md:after:h-1/2 md:after:w-px md:after:bg-[var(--color-accent)]/15' : ''}`}>
              <div class="stat-number font-display text-[clamp(1.75rem,4vw,3rem)] leading-none text-[var(--color-accent)] mb-1" data-target={stat.number} data-suffix={stat.suffix}>
                0{stat.suffix}
              </div>
              <div class="text-[0.6rem] uppercase tracking-[0.15em] text-[var(--color-text-muted)]/80">
                {stat.label}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function() {
    // CountUp animation
    const statBar = document.querySelector('.stat-bar');
    const statNumbers = document.querySelectorAll('.stat-number');
    let counted = false;

    const easeOutExpo = (t: number) => (t === 1 ? 1 : 1 - Math.pow(2, -10 * t));

    const countUp = (el: HTMLElement, target: number, suffix: string, duration = 1500) => {
      const start = performance.now();
      const step = (now: number) => {
        const progress = Math.min((now - start) / duration, 1);
        const eased = easeOutExpo(progress);
        const current = Math.round(eased * target);
        el.textContent = current + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !counted) {
          counted = true;
          statNumbers.forEach((el) => {
            const target = parseInt(el.getAttribute('data-target') || '0', 10);
            const suffix = el.getAttribute('data-suffix') || '';
            countUp(el as HTMLElement, target, suffix);
          });
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });

    if (statBar) observer.observe(statBar);
  })();
</script>

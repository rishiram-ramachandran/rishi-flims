---
interface Service {
  id: string;
  title: string;
  description: string;
  icon: string;
  size: string;
}

const services: Service[] = [
  {
    id: 'videography',
    title: 'Business Videography',
    description: 'On-location shoots for business owners: products, spaces, processes, people.',
    icon: 'camera',
    size: 'large'
  },
  {
    id: 'editing',
    title: 'Video Editing',
    description: 'Color grading, sound design, pacing — turning raw footage into a finished story.',
    icon: 'scissors',
    size: 'small'
  },
  {
    id: 'branding',
    title: 'Brand Promotions',
    description: 'End-to-end influencer marketing — concept, shoot, edit, and publish promotional content on my own platform for brands.',
    icon: 'trending-up',
    size: 'small'
  },
  {
    id: 'storytelling',
    title: 'Cinematic Storytelling',
    description: 'Narrative-driven short films and reels that captivate and convert.',
    icon: 'film',
    size: 'large'
  },
  {
    id: 'talking-head',
    title: 'Talking Head Content',
    description: 'Clean, professional presenter-style videos for founders, creators, and brands.',
    icon: 'mic',
    size: 'small'
  }
];

const getIcon = (iconName: string) => {
  const icons: Record<string, string> = {
    camera: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>',
    scissors: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>',
    'trending-up': '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>',
    film: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/></svg>',
    mic: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v12a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>'
  };
  return icons[iconName] || '';
};
---

<section id="services" class="py-32 md:py-40 lg:py-48">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-16 md:mb-24 animate-on-scroll">
      <p class="text-[var(--color-accent)] text-sm font-semibold tracking-[0.2em] uppercase mb-4">Services</p>
      <h2 class="font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.9] tracking-wide text-[var(--color-text)]">
        WHAT I DO
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
      {services.map((service) => (
        <div
          class={`group animate-on-scroll scale-in relative p-8 md:p-10 rounded-3xl bg-[var(--color-bg-secondary)] border border-[var(--color-border)] transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:border-[var(--color-accent)]/30 hover:-translate-y-2 hover:shadow-[0_20px_60px_-15px_rgba(200,169,107,0.12)] ${service.size === 'large' ? 'md:col-span-2 lg:col-span-2' : ''}`}
        >
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-[var(--color-accent)]/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          <div class="relative z-10">
            <div class="w-12 h-12 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center text-[var(--color-accent)] mb-6 group-hover:scale-110 transition-transform duration-500">
              <Fragment set:html={getIcon(service.icon)} />
            </div>
            <h3 class="font-display text-2xl md:text-3xl tracking-wide text-[var(--color-text)] mb-3">
              {service.title}
            </h3>
            <p class="text-[var(--color-text-muted)] leading-relaxed text-base">
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

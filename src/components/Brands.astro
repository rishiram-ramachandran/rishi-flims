---
// Brand Collaborations Section - Display of brands worked with
// Currently using styled text badges; can be replaced with logo SVGs from /public/logos/

const brands = ['TVS', 'TVS Racing', 'Oppo India', 'Vivo', 'Insta360'];
---

<section id="brands" class="brands">
  <div class="container">
    <div class="section-heading text-center">
      <h2>Trusted By</h2>
      <p>Brands I've created promotional content for</p>
    </div>
    <div class="brands-marquee fade-in">
      {brands.map((brand) => (
        <div class="brand-badge">{brand}</div>
      ))}
      {brands.map((brand) => (
        <div class="brand-badge" aria-hidden="true">{brand}</div>
      ))}
    </div>
  </div>
</section>

<style>
  .brands {
    background: rgba(255, 255, 255, 0.02);
    padding: 4rem 2rem;
  }

  @media (min-width: 768px) {
    .brands {
      padding: 6rem 4rem;
    }
  }

  @media (min-width: 1024px) {
    .brands {
      padding: 8rem 6rem;
    }
  }

  .brands-marquee {
    display: flex;
    gap: 2rem;
    overflow-x: auto;
    justify-content: center;
    flex-wrap: wrap;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .brand-badge {
    background: rgba(212, 165, 116, 0.1);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: var(--transition);
    scroll-snap-align: center;
  }

  .brand-badge:hover {
    background: rgba(212, 165, 116, 0.2);
    transform: translateY(-3px);
    box-shadow: 0 0 20px rgba(212, 165, 116, 0.2);
  }

  @media (max-width: 768px) {
    .brands-marquee {
      gap: 1rem;
    }

    .brand-badge {
      padding: 0.75rem 1.5rem;
      font-size: 0.85rem;
    }
  }
</style>

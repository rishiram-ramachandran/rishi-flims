---
// Brand Collaborations Section - Display of brands worked with
// Currently using styled text badges; can be replaced with logo SVGs from /public/logos/

const brands = ['TVS', 'TVS Racing', 'Oppo India', 'Vivo', 'Insta360'];
---

<section id="brands" class="brands">
  <div class="container">
    <div class="section-heading text-center">
      <h2>Trusted By</h2>
      <p>Brands I've created promotional content for</p>
      <p class="brands-supporting">
        Multiple brand partnerships across two-wheeler, smartphone, and camera tech industries — from product reveals to influencer-style promotional reels.
      </p>
    </div>
    <div class="brands-marquee fade-in">
      {brands.map((brand) => (
        <div class="brand-badge">{brand}</div>
      ))}
      {brands.map((brand) => (
        <div class="brand-badge" aria-hidden="true">{brand}</div>
      ))}
    </div>

    <div class="brands-stats fade-in">
      <div class="stat-item">
        <span class="stat-number">5+</span>
        <span class="stat-label">Brand Collaborations</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">3+</span>
        <span class="stat-label">Tech Industries</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">100%</span>
        <span class="stat-label">Concept to Publish</span>
      </div>
    </div>
  </div>
</section>

<style>
  .brands {
    background: rgba(255, 255, 255, 0.02);
    padding: 4rem 2rem;
  }

  @media (min-width: 768px) {
    .brands {
      padding: 6rem 4rem;
    }
  }

  @media (min-width: 1024px) {
    .brands {
      padding: 8rem 6rem;
    }
  }

  .brands-supporting {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 700px;
    margin: 0.75rem auto 0 auto;
    line-height: 1.6;
  }

  .brands-marquee {
    display: flex;
    gap: 2rem;
    overflow-x: auto;
    justify-content: center;
    flex-wrap: wrap;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .brand-badge {
    background: rgba(212, 165, 116, 0.1);
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: var(--transition);
    scroll-snap-align: center;
  }

  .brand-badge:hover {
    background: rgba(212, 165, 116, 0.2);
    transform: translateY(-3px);
    box-shadow: 0 0 20px rgba(212, 165, 116, 0.2);
  }

  .brands-stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
    margin-top: 3.5rem;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .brands-marquee {
      gap: 1rem;
    }

    .brand-badge {
      padding: 0.75rem 1.5rem;
      font-size: 0.85rem;
    }

    .brands-stats {
      gap: 2rem;
      margin-top: 2.5rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .stat-label {
      font-size: 0.75rem;
    }
  }
</style>

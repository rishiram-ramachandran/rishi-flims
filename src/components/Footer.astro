---
import siteData from '../data/site.json';
import LogoFull from './icons/LogoFull.astro';

const { social } = siteData;
---

<footer class="py-8 md:py-10 border-t border-[var(--color-border)]">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="flex flex-col md:flex-row items-center justify-between gap-5">
      <div class="text-center md:text-left">
        <div class="flex items-center justify-center md:justify-start gap-2.5 mb-1.5 text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors duration-300">
          <LogoFull size={22} color="currentColor" />
        </div>
        <p class="text-[var(--color-text-muted)] text-xs">&copy; 2026 Rishi Films. All rights reserved.</p>
      </div>

      <div class="flex items-center gap-3">
        <a
          href={social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-full border border-[var(--color-border-light)] bg-[var(--color-bg-secondary)]/50 flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-all duration-300"
          aria-label="Instagram"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37"/>
            <circle cx="17.5" cy="6.5" r="1.5"/>
          </svg>
        </a>
        <a
          href={social.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="w-9 h-9 rounded-full border border-[var(--color-border-light)] bg-[var(--color-bg-secondary)]/50 flex items-center justify-center text-[var(--color-text-muted)] hover:text-[#25D366] hover:border-[#25D366]/40 transition-all duration-300"
          aria-label="WhatsApp"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
        <a
          href={social.email}
          class="w-9 h-9 rounded-full border border-[var(--color-border-light)] bg-[var(--color-bg-secondary)]/50 flex items-center justify-center text-[var(--color-text-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)]/40 transition-all duration-300"
          aria-label="Email"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-10 5L2 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

---
import siteData from '../data/site.json';

const { contact, social } = siteData;
---

<section id="contact" class="contact">
  <div class="container">
    <div class="contact-content max-w-800 text-center fade-in">
      <h2>Let's Make Something Cinematic</h2>
      <p class="contact-subtext">
        Got a product, a launch, or a story to tell? Let's create something that gets noticed.
      </p>

      <div class="contact-info mt-lg">
        <div class="info-item">
          <label>Name</label>
          <p>{contact.name}</p>
        </div>
        <div class="info-item">
          <label>Phone / WhatsApp</label>
          <p>
            <a href={`tel:${contact.phone.replace(/[\s-]/g, '')}`}>{contact.phone}</a>
            <span class="separator" style="margin: 0 0.5rem; color: rgba(255,255,255,0.15);">|</span>
            <a href={contact.whatsapp} target="_blank" rel="noopener noreferrer" class="whatsapp-direct" style="color: #25D366; font-weight: 600;">
              Chat
            </a>
          </p>
        </div>
        <div class="info-item">
          <label>Email</label>
          <p>
            <a href={`mailto:${contact.email}`}>{contact.email}</a>
          </p>
        </div>
        <div class="info-item">
          <label>Location</label>
          <p>{contact.location}</p>
        </div>
      </div>

      <div class="contact-buttons btn-group mt-lg">
        <a href={contact.whatsapp} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
          Message on WhatsApp
        </a>
        <a href={`mailto:${contact.email}`} class="btn">
          Email Me
        </a>
      </div>

      <div class="social-links mt-lg">
        <p class="social-label">Also on Instagram:</p>
        <div class="social-links-list">
          <a href={contact.instagram_secondary} class="social-link" target="_blank" rel="noopener noreferrer">
            @rishi_.films_
          </a>
          <span class="separator">•</span>
          <a href={contact.instagram} class="social-link" target="_blank" rel="noopener noreferrer">
            @iam_.anonymous__
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: linear-gradient(
      135deg,
      rgba(212, 165, 116, 0.05) 0%,
      rgba(212, 165, 116, 0.02) 100%
    );
    border-top: 1px solid var(--color-border);
  }

  .contact-subtext {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-top: 1rem;
  }

  .contact-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin: 2rem 0;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .info-item label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .info-item p {
    font-size: 1rem;
    color: var(--color-light);
  }

  .info-item a {
    color: var(--color-accent);
    transition: var(--transition);
  }

  .info-item a:hover {
    text-decoration: underline;
  }

  .contact-buttons {
    flex-direction: column;
  }

  .contact-buttons .btn {
    min-width: 250px;
  }

  .social-label {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .social-links-list {
    display: flex;
    gap: 1rem;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
  }

  .social-link {
    color: var(--color-accent);
    font-weight: 500;
    transition: var(--transition);
  }

  .social-link:hover {
    text-decoration: underline;
  }

  .separator {
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .contact-buttons {
      flex-direction: column;
    }

    .contact-buttons .btn {
      width: 100%;
      min-width: auto;
    }

    .contact-info {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>

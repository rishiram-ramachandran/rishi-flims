---
import siteData from '../data/site.json';

const { contact } = siteData;
---

<section id="contact" class="relative py-16 md:py-20 lg:py-24 overflow-hidden">
  <!-- Background image with parallax -->
  <div class="absolute inset-0">
    <img
      src="https://images.pexels.com/photos/3062545/pexels-photo-3062545.jpeg?auto=compress&cs=tinysrgb&w=1920"
      alt=""
      class="contact-bg w-full h-full object-cover scale-110"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-[var(--color-bg)]/85"></div>
    <div class="absolute inset-0 noise-overlay"></div>
  </div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-3xl mx-auto text-center">
      <div data-reveal="fade-up">
        <!-- Availability badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 mb-5">
          <span class="relative flex h-1.5 w-1.5">
            <span class="contact-ping absolute inline-flex h-full w-full rounded-full bg-[var(--color-accent)] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-[var(--color-accent)]"></span>
          </span>
          <span class="text-[var(--color-accent)] text-[10px] font-semibold tracking-wider uppercase">Currently accepting projects</span>
        </div>

        <h2 class="font-display text-[clamp(2.5rem,6vw,4rem)] leading-[0.9] tracking-wide text-[var(--color-text)] mb-3" data-reveal="line">
          LET'S MAKE SOMETHING CINEMATIC
        </h2>

        <p class="text-[var(--color-text-muted)] text-base leading-relaxed max-w-lg mx-auto mb-8">
          Got a product, a launch, or a story to tell? Let's create something that gets noticed.
        </p>
      </div>
    </div>

    <!-- Single card with partition -->
    <div class="max-w-4xl mx-auto" data-reveal="scale-in">
      <div class="glass rounded-2xl overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <!-- Left: Contact Info -->
          <div class="p-6 md:p-8 text-left border-b md:border-b-0 md:border-r border-[var(--color-border-light)]" data-reveal-stagger>
            <h3 class="font-display text-lg tracking-wide text-[var(--color-text)] mb-5">GET IN TOUCH</h3>
            <div class="space-y-3.5">
              <div data-reveal="fade-up">
                <p class="text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Name</p>
                <p class="text-[var(--color-text)] text-sm font-medium">{contact.name}</p>
              </div>
              <div data-reveal="fade-up">
                <p class="text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Location</p>
                <p class="text-[var(--color-text)] text-sm font-medium">{contact.location}</p>
              </div>
              <div data-reveal="fade-up">
                <p class="text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Phone</p>
                <a href={`tel:${contact.phone.replace(/[\s-]/g, '')}`} class="text-[var(--color-text)] text-sm font-medium hover:text-[var(--color-accent)] transition-colors duration-300" data-cursor-grow>
                  {contact.phone}
                </a>
              </div>
              <div data-reveal="fade-up">
                <p class="text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Email</p>
                <a href={`mailto:${contact.email}`} class="text-[var(--color-text)] text-sm font-medium hover:text-[var(--color-accent)] transition-colors duration-300" data-cursor-grow>
                  {contact.email}
                </a>
              </div>
            </div>

            <div class="mt-6 pt-5 border-t border-[var(--color-border-light)] flex flex-col gap-2">
              <a
                href={contact.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="group w-full inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-[#25D366] text-white text-sm font-semibold tracking-wider uppercase rounded-full hover:bg-[#128C7E] transition-all duration-300"
                data-cursor-grow
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp Me
              </a>
              <div class="flex gap-2">
                <a
                  href={contact.instagram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 border border-[var(--color-border-light)] text-[var(--color-text)] text-xs font-medium tracking-wide rounded-full hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] transition-all duration-300"
                  data-cursor-grow
                >
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37"/>
                    <circle cx="17.5" cy="6.5" r="1.5"/>
                  </svg>
                  Instagram
                </a>
                <a
                  href={`mailto:${contact.email}`}
                  class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-2 border border-[var(--color-border-light)] text-[var(--color-text)] text-xs font-medium tracking-wide rounded-full hover:border-[var(--color-accent)]/40 hover:text-[var(--color-accent)] transition-all duration-300"
                  data-cursor-grow
                >
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2"/>
                    <path d="m22 7-10 5L2 7"/>
                  </svg>
                  Email
                </a>
              </div>
            </div>
          </div>

          <!-- Right: Contact Form -->
          <div class="p-6 md:p-8 text-left">
            <h3 class="font-display text-lg tracking-wide text-[var(--color-text)] mb-5">SEND A MESSAGE</h3>
            <form id="contact-form" action="https://formsubmit.co/rishiramramachandran@gmail.com" method="POST" class="space-y-3.5">
              <input type="hidden" name="_subject" value="New Project Inquiry - Rishi Films" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="hidden" name="_template" value="table" />
              <input type="hidden" name="_next" value="https://rishiram-ramachandran.github.io/rishi-flims/?form=success" />

              <div class="input-animated relative">
                <label for="name" class="block text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-3.5 py-2 rounded-lg bg-[var(--color-bg)]/60 border border-[var(--color-border-light)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)]/50 focus:outline-none focus:border-[var(--color-accent)]/50 transition-colors duration-300"
                  placeholder="Your name"
                />
              </div>
              <div class="input-animated relative">
                <label for="email" class="block text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-3.5 py-2 rounded-lg bg-[var(--color-bg)]/60 border border-[var(--color-border-light)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)]/50 focus:outline-none focus:border-[var(--color-accent)]/50 transition-colors duration-300"
                  placeholder="your@email.com"
                />
              </div>
              <div class="input-animated relative">
                <label for="phone" class="block text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-3.5 py-2 rounded-lg bg-[var(--color-bg)]/60 border border-[var(--color-border-light)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)]/50 focus:outline-none focus:border-[var(--color-accent)]/50 transition-colors duration-300"
                  placeholder="+91 00000 00000"
                />
              </div>
              <div class="input-animated relative">
                <label for="message" class="block text-[var(--color-text-muted)] text-[10px] font-semibold tracking-wider uppercase mb-1">Project Details</label>
                <textarea
                  id="message"
                  name="message"
                  rows="3"
                  required
                  class="w-full px-3.5 py-2 rounded-lg bg-[var(--color-bg)]/60 border border-[var(--color-border-light)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-muted)]/50 focus:outline-none focus:border-[var(--color-accent)]/50 transition-colors duration-300 resize-none"
                  placeholder="Tell me about your project..."
                ></textarea>
              </div>
              <button
                type="submit"
                id="submit-btn"
                class="submit-btn w-full relative inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-[var(--color-accent)] text-[var(--color-bg)] text-sm font-semibold tracking-wider uppercase rounded-full overflow-hidden transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed group"
                data-cursor-grow
              >
                <span class="relative z-10" id="btn-text">Send Message</span>
                <svg id="btn-spinner" class="relative z-10 w-4 h-4 animate-spin hidden" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.25"/>
                  <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                </svg>
                <!-- Liquid fill overlay -->
                <span class="absolute inset-0 bg-[var(--color-text)] translate-y-full group-hover:translate-y-0 transition-transform duration-300"></span>
              </button>
            </form>

            <div id="form-success" class="hidden mt-4 p-4 rounded-lg bg-[#25D366]/10 border border-[#25D366]/20 text-center">
              <p class="text-[#25D366] text-sm font-medium">Thank you. I'll get back to you shortly.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-bg {
    will-change: transform;
  }

  @keyframes contact-ping {
    0% { transform: scale(1); opacity: 0.75; }
    100% { transform: scale(2); opacity: 0; }
  }

  .contact-ping {
    animation: contact-ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  /* Submit button liquid fill */
  .submit-btn:hover span:nth-child(3) {
    transform: translateY(0);
  }

  .submit-btn:hover #btn-text,
  .submit-btn:hover #btn-spinner {
    color: var(--color-bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-ping {
      animation: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  (function() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Parallax background
    if (!prefersReducedMotion) {
      const bg = document.querySelector('.contact-bg');
      if (bg) {
        gsap.to(bg, {
          yPercent: -10,
          ease: 'none',
          scrollTrigger: {
            trigger: '#contact',
            start: 'top bottom',
            end: 'bottom top',
            scrub: 0.6
          }
        });
      }
    }

    // Form handling
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const btnText = document.getElementById('btn-text');
    const btnSpinner = document.getElementById('btn-spinner');
    const successMsg = document.getElementById('form-success');

    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('form') === 'success') {
      form?.classList.add('hidden');
      successMsg?.classList.remove('hidden');
      window.history.replaceState({}, '', window.location.pathname);
    }

    form?.addEventListener('submit', () => {
      if (submitBtn) {
        submitBtn.disabled = true;
        btnText?.classList.add('hidden');
        btnSpinner?.classList.remove('hidden');
      }
    });
  })();
</script>

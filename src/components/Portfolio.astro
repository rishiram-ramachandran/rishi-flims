---
import VideoCarousel from './VideoCarousel.astro';
import videosData from '../data/videos.json';
---

<section id="portfolio" class="py-16 md:py-20 lg:py-24">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="mb-8 md:mb-10" data-reveal="fade-up">
      <p class="text-[var(--color-accent)] text-xs font-semibold tracking-[0.2em] uppercase mb-2">Portfolio</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[0.9] tracking-wide text-[var(--color-text)] mb-3" data-reveal="line">
        SELECTED WORK
      </h2>
      <p class="text-[var(--color-text-muted)] text-sm max-w-lg">
        A curated collection of brand collaborations, cinematic reels, and talking head content.
      </p>
    </div>

    <div class="space-y-10 md:space-y-14">
      {videosData.categories.map((category) => (
        <VideoCarousel category={category} />
      ))}
    </div>
  </div>
</section>

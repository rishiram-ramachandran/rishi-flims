---
import VideoCarousel from './VideoCarousel.astro';
import videosData from '../data/videos.json';
---

<section id="portfolio" class="py-32 md:py-40 lg:py-48">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="mb-16 md:mb-24 animate-on-scroll">
      <p class="text-[var(--color-accent)] text-sm font-semibold tracking-[0.2em] uppercase mb-4">Portfolio</p>
      <h2 class="font-display text-[clamp(2.5rem,5vw,4.5rem)] leading-[0.9] tracking-wide text-[var(--color-text)] mb-6">
        SELECTED WORK
      </h2>
      <p class="text-[var(--color-text-muted)] text-lg max-w-xl">
        A curated collection of brand collaborations, cinematic reels, and talking head content.
      </p>
    </div>

    <div class="space-y-20 md:space-y-28">
      {videosData.categories.map((category) => (
        <VideoCarousel category={category} />
      ))}
    </div>
  </div>
</section>

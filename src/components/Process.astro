---
const steps = [
  {
    num: "01",
    title: "BRIEF & DISCOVERY",
    desc: "We start with a conversation. I learn your brand, your audience, and the story you need told — before a single frame is shot.",
  },
  {
    num: "02",
    title: "CONCEPT & STORYBOARD",
    desc: "Every shoot starts on paper. I map out the visual story — scenes, angles, mood, and messaging — so nothing is left to chance on location.",
  },
  {
    num: "03",
    title: "PRODUCTION",
    desc: "On-location shoot with professional lighting, stabilization, and direction. I handle the camera, the composition, and the performance.",
  },
  {
    num: "04",
    title: "POST-PRODUCTION",
    desc: "Color grading, sound design, motion graphics, and pacing — in DaVinci Resolve. Raw footage becomes a finished cinematic story.",
  },
  {
    num: "05",
    title: "DELIVERY & PUBLISHING",
    desc: "Final files in your preferred format, with optional publishing support. For brand promotions, I publish directly on my platform to drive reach.",
  },
];
---

<section id="process" class="relative py-20 md:py-28 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-16 md:mb-20 animate-on-scroll">
      <p class="text-[var(--color-accent)] text-xs font-semibold tracking-[0.2em] uppercase mb-3">Process</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3.5rem)] leading-[0.9] tracking-wide text-[var(--color-text)]">
        HOW IT WORKS
      </h2>
    </div>

    <!-- Desktop: staggered timeline -->
    <div class="hidden md:block relative">
      <!-- Center line -->
      <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-[var(--color-accent)]/30 to-transparent -translate-x-1/2"></div>

      <div class="space-y-20 lg:space-y-24">
        {steps.map((step, i) => {
          const isLeft = i % 2 === 0;
          return (
            <div class={`process-step flex items-center gap-8 lg:gap-16 ${isLeft ? 'flex-row' : 'flex-row-reverse'}`}>
              <!-- Content side -->
              <div class={`flex-1 ${isLeft ? 'text-right pr-8 lg:pr-12' : 'text-left pl-8 lg:pl-12'}`}>
                <div class="relative inline-block">
                  <span class="process-num absolute font-display text-[8rem] lg:text-[10rem] leading-none text-[var(--color-text)]/[0.03] select-none pointer-events-none"
                    style={`${isLeft ? 'right: 0; transform: translateX(30%);' : 'left: 0; transform: translateX(-30%);'} top: 50%; margin-top: -5rem;`}>
                    {step.num}
                  </span>
                  <div class="relative z-10">
                    <p class="text-[var(--color-accent)] text-[10px] font-semibold tracking-[0.25em] uppercase mb-2">
                      Step {step.num}
                    </p>
                    <h3 class="font-display text-xl lg:text-2xl tracking-wide text-[var(--color-text)] mb-3">
                      {step.title}
                    </h3>
                    <p class="text-[var(--color-text-muted)] text-sm leading-relaxed max-w-md">
                      {step.desc}
                    </p>
                  </div>
                </div>
              </div>

              <!-- Center dot -->
              <div class="relative z-10 flex-shrink-0">
                <div class="w-3 h-3 rounded-full bg-[var(--color-accent)] ring-4 ring-[var(--color-bg)]"></div>
              </div>

              <!-- Spacer side -->
              <div class="flex-1"></div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Mobile: single column with left border -->
    <div class="md:hidden relative">
      <!-- Left accent line -->
      <div class="absolute left-[11px] top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-[var(--color-accent)]/40 to-transparent"></div>

      <div class="space-y-10">
        {steps.map((step) => (
          <div class="process-step relative pl-8">
            <!-- Dot -->
            <div class="absolute left-0 top-1 w-[22px] h-[22px] flex items-center justify-center">
              <div class="w-2.5 h-2.5 rounded-full bg-[var(--color-accent)] ring-[3px] ring-[var(--color-bg)]"></div>
            </div>

            <div class="relative">
              <span class="process-num absolute font-display text-[6rem] leading-none text-[var(--color-text)]/[0.04] select-none pointer-events-none -left-2 -top-6">
                {step.num}
              </span>
              <div class="relative z-10">
                <p class="text-[var(--color-accent)] text-[10px] font-semibold tracking-[0.25em] uppercase mb-1.5">
                  Step {step.num}
                </p>
                <h3 class="font-display text-lg tracking-wide text-[var(--color-text)] mb-2">
                  {step.title}
                </h3>
                <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">
                  {step.desc}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .process-step {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }
  .process-step.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  (function() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const step = entry.target;
          const siblings = Array.from(document.querySelectorAll('.process-step'));
          const index = siblings.indexOf(step);
          setTimeout(() => {
            step.classList.add('visible');
          }, index * 120);
          observer.unobserve(step);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -40px 0px',
    });

    document.querySelectorAll('.process-step').forEach((step) => {
      observer.observe(step);
    });
  })();
</script>

---
const steps = [
  {
    num: "01",
    title: "BRIEF & DISCOVERY",
    desc: "We start with a conversation. I learn your brand, your audience, and the story you need told — before a single frame is shot.",
  },
  {
    num: "02",
    title: "CONCEPT & STORYBOARD",
    desc: "Every shoot starts on paper. I map out the visual story — scenes, angles, mood, and messaging — so nothing is left to chance on location.",
  },
  {
    num: "03",
    title: "PRODUCTION",
    desc: "On-location shoot with professional lighting, stabilization, and direction. I handle the camera, the composition, and the performance.",
  },
  {
    num: "04",
    title: "POST-PRODUCTION",
    desc: "Color grading, sound design, motion graphics, and pacing — in DaVinci Resolve. Raw footage becomes a finished cinematic story.",
  },
  {
    num: "05",
    title: "DELIVERY & PUBLISHING",
    desc: "Final files in your preferred format, with optional publishing support. For brand promotions, I publish directly on my platform to drive reach.",
  },
];
---

<section id="process" class="relative py-16 md:py-20 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-10 md:mb-12 animate-on-scroll">
      <p class="text-[var(--color-accent)] text-xs font-semibold tracking-[0.2em] uppercase mb-3">Process</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[0.9] tracking-wide text-[var(--color-text)]">
        HOW IT WORKS
      </h2>
    </div>

    <!-- Desktop: compact horizontal cards with watermark numbers -->
    <div class="hidden md:block">
      <div class="grid grid-cols-5 gap-3 lg:gap-4">
        {steps.map((step, i) => (
          <div class="process-step group relative overflow-hidden rounded-2xl bg-[var(--color-bg-secondary)]/40 border border-[var(--color-border)]/50 p-5 lg:p-6 transition-all duration-500 hover:border-[var(--color-accent)]/20 hover:-translate-y-1 hover:shadow-[0_12px_40px_-8px_rgba(212,175,55,0.08)]">
            <!-- Watermark number -->
            <span class="absolute -right-2 -top-4 font-display text-[5rem] lg:text-[6rem] leading-none text-[var(--color-text)]/[0.04] select-none pointer-events-none transition-all duration-500 group-hover:text-[var(--color-accent)]/[0.06]">
              {step.num}
            </span>

            <div class="relative z-10">
              <!-- Step indicator -->
              <div class="flex items-center gap-2 mb-3">
                <div class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
                  <span class="font-display text-[10px] text-[var(--color-accent)]">{step.num}</span>
                </div>
                {i < steps.length - 1 && (
                  <div class="flex-1 h-px bg-gradient-to-r from-[var(--color-accent)]/20 to-transparent"></div>
                )}
              </div>

              <h3 class="font-display text-sm lg:text-base tracking-wide text-[var(--color-text)] mb-2 leading-tight">
                {step.title}
              </h3>
              <p class="text-[var(--color-text-muted)] text-xs leading-relaxed">
                {step.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Mobile: compact horizontal scroll -->
    <div class="md:hidden">
      <div class="flex gap-3 overflow-x-auto scroll-snap-x pb-2 -mx-6 px-6" id="process-scroll">
        {steps.map((step) => (
          <div class="process-step flex-shrink-0 w-[78vw] max-w-[300px] scroll-snap-start relative overflow-hidden rounded-2xl bg-[var(--color-bg-secondary)]/40 border border-[var(--color-border)]/50 p-5">
            <span class="absolute -right-2 -top-4 font-display text-[5rem] leading-none text-[var(--color-text)]/[0.04] select-none pointer-events-none">
              {step.num}
            </span>
            <div class="relative z-10">
              <div class="flex items-center gap-2 mb-3">
                <div class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
                  <span class="font-display text-[10px] text-[var(--color-accent)]">{step.num}</span>
                </div>
              </div>
              <h3 class="font-display text-base tracking-wide text-[var(--color-text)] mb-2 leading-tight">
                {step.title}
              </h3>
              <p class="text-[var(--color-text-muted)] text-xs leading-relaxed">
                {step.desc}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Mobile dots -->
      <div class="flex items-center justify-center gap-1.5 mt-4" id="process-dots">
        {steps.map((_, i) => (
          <button
            class="process-dot w-1.5 h-1.5 rounded-full bg-[var(--color-text-muted)]/30 transition-all duration-300"
            data-index={i}
            aria-label={`Go to step ${i + 1}`}
          />
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .scroll-snap-x {
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scroll-snap-x::-webkit-scrollbar {
    display: none;
  }
  .scroll-snap-start {
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }
  .process-step {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
  }
  .process-step.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .process-dot.active {
    background-color: var(--color-accent);
    width: 1.25rem;
    border-radius: 9999px;
  }
</style>

<script>
  (function() {
    // IntersectionObserver for reveal animation
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const step = entry.target;
          const siblings = Array.from(document.querySelectorAll('.process-step'));
          const index = siblings.indexOf(step);
          setTimeout(() => {
            step.classList.add('visible');
          }, index * 80);
          observer.unobserve(step);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -20px 0px',
    });

    document.querySelectorAll('.process-step').forEach((step) => {
      observer.observe(step);
    });

    // Mobile scroll dots
    const scrollTrack = document.getElementById('process-scroll');
    const dots = document.querySelectorAll('.process-dot');
    if (scrollTrack && dots.length > 0) {
      const updateDots = () => {
        const scrollLeft = scrollTrack.scrollLeft;
        const cardWidth = scrollTrack.querySelector('.process-step')?.clientWidth || 300;
        const gap = 12;
        const index = Math.round(scrollLeft / (cardWidth + gap));
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });
      };
      scrollTrack.addEventListener('scroll', updateDots, { passive: true });
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = parseInt(dot.getAttribute('data-index') || '0');
          const cardWidth = scrollTrack.querySelector('.process-step')?.clientWidth || 300;
          const gap = 12;
          scrollTrack.scrollTo({ left: idx * (cardWidth + gap), behavior: 'smooth' });
        });
      });
      updateDots();
    }
  })();
</script>

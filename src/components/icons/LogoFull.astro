---
interface Props {
  size?: number | string;
  color?: string;
  accent?: string;
  class?: string;
}

const {
  size = "auto",
  color = "currentColor",
  accent = "#C8A96B",
  class: className = ""
} = Astro.props;

const heightAttr = size === "auto" ? undefined : size;
---

<svg
  height={heightAttr}
  viewBox="0 0 260 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={`w-auto max-w-full ${className}`}
>
  <!-- LogoMark Monogram Centered in 0 0 64 64 -->
  <g transform="translate(0, 0)">
    <!-- Outer Aperture Ring -->
    <circle
      cx="32"
      cy="32"
      r="28"
      stroke={color}
      stroke-width="1.5"
      opacity="0.2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    
    <!-- Lens Ticks -->
    <line x1="32" y1="4" x2="32" y2="7" stroke={color} stroke-width="1.5" stroke-linecap="round" />
    <line x1="32" y1="57" x2="32" y2="60" stroke={color} stroke-width="1.5" stroke-linecap="round" />
    <line x1="4" y1="32" x2="7" y2="32" stroke={color} stroke-width="1.5" stroke-linecap="round" />
    <line x1="57" y1="32" x2="60" y2="32" stroke={color} stroke-width="1.5" stroke-linecap="round" />
    
    <!-- Monogram: Stems & Connections -->
    <!-- R Stem (White) -->
    <line
      x1="22"
      y1="20"
      x2="22"
      y2="44"
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    
    <!-- R Diagonal Leg (White) -->
    <line
      x1="22"
      y1="32"
      x2="34"
      y2="44"
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    
    <!-- R Bowl Bottom (White) -->
    <line
      x1="22"
      y1="32"
      x2="42"
      y2="32"
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    
    <!-- R Bowl Curve (White) -->
    <path
      d="M 22 32 C 22 24.5 27.5 20 32 20"
      stroke={color}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
    
    <!-- Gold Accent Corner (Gold) -->
    <path
      d="M 32 20 H 42 V 32"
      stroke={accent}
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </g>

  <!-- Wordmark Text -->
  <text
    x="76"
    y="41"
    fill={color}
    font-family="'Bebas Neue', sans-serif"
    font-size="28"
    letter-spacing="0.25em"
  >RISHI FILMS</text>
</svg>

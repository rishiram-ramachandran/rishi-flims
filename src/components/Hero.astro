---
// Hero Section - Main landing area with tagline and CTAs
---

<section id="hero" class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content fade-in">
    <h1 class="hero-title">Rishi Films</h1>
    <p class="hero-tagline">Cinematic stories for businesses that mean business.</p>
    <p class="hero-subtext">Videography & Video Editing for Brands and Business Owners</p>
    <div class="btn-group mt-lg">
      <a href="#portfolio" class="btn">View My Work</a>
      <a href="#contact" class="btn btn-primary">Get In Touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    padding: 4rem 2rem;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -1px;
    animation: float 4s ease-in-out infinite;
  }

  .hero-tagline {
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--color-light);
    margin-bottom: 1rem;
    font-weight: 400;
  }

  .hero-subtext {
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 6rem 2rem 4rem;
    }
  }
</style>

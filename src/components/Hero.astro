---
import siteData from '../data/site.json';

const { contact } = siteData;
---

<section id="hero" class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="https://images.pexels.com/photos/3062541/pexels-photo-3062541.jpeg?auto=compress&cs=tinysrgb&w=1920"
      alt=""
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-[var(--color-bg)]/70"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/30 via-transparent to-[var(--color-bg)]"></div>
    <div class="absolute inset-0 noise-overlay vignette"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <!-- Logo mark -->
    <div class="mb-8 animate-on-scroll">
      <svg width="64" height="64" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto text-[var(--color-accent)]">
        <circle cx="20" cy="20" r="17" stroke="currentColor" stroke-width="1.5" opacity="0.9"/>
        <path d="M20 3 L23 8 L17 8 Z" fill="currentColor" opacity="0.8"/>
        <path d="M20 37 L17 32 L23 32 Z" fill="currentColor" opacity="0.8"/>
        <path d="M3 20 L8 17 L8 23 Z" fill="currentColor" opacity="0.8"/>
        <path d="M37 20 L32 23 L32 17 Z" fill="currentColor" opacity="0.8"/>
        <path d="M7 7 L11 10 L10 12 Z" fill="currentColor" opacity="0.5"/>
        <path d="M33 33 L29 30 L30 28 Z" fill="currentColor" opacity="0.5"/>
        <path d="M33 7 L29 10 L30 12 Z" fill="currentColor" opacity="0.5"/>
        <path d="M7 33 L11 30 L10 28 Z" fill="currentColor" opacity="0.5"/>
        <text x="20" y="25" text-anchor="middle" font-family="'Bebas Neue', sans-serif" font-size="16" fill="currentColor" font-weight="400" letter-spacing="0.5">R</text>
      </svg>
    </div>

    <h1 class="font-display text-[clamp(4rem,15vw,12rem)] leading-[0.85] tracking-[0.08em] text-[var(--color-text)] animate-on-scroll">
      RISHI FILMS
    </h1>

    <p class="mt-6 text-[clamp(1.1rem,2.5vw,1.75rem)] font-light text-[var(--color-text)] tracking-wide leading-relaxed max-w-2xl mx-auto animate-on-scroll" style="transition-delay: 100ms;">
      Cinematic stories for businesses that mean business.
    </p>

    <p class="mt-3 text-[clamp(0.85rem,1.5vw,1.05rem)] text-[var(--color-text-muted)] tracking-wide max-w-xl mx-auto animate-on-scroll" style="transition-delay: 200ms;">
      Videography & Video Editing for Brands and Business Owners
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3 animate-on-scroll" style="transition-delay: 300ms;">
      <a
        href="#portfolio"
        class="group inline-flex items-center gap-2 px-7 py-3.5 border border-[var(--color-accent)]/60 text-[var(--color-accent)] text-sm font-semibold tracking-wider uppercase rounded-full hover:bg-[var(--color-accent)] hover:text-[var(--color-bg)] transition-all duration-300"
      >
        View My Work
        <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <a
        href={contact.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2 px-7 py-3.5 bg-[#25D366] text-white text-sm font-semibold tracking-wider uppercase rounded-full hover:bg-[#128C7E] transition-all duration-300"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp Me
      </a>
    </div>

    <div class="mt-8 animate-on-scroll" style="transition-delay: 400ms;">
      <a
        href={contact.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors duration-300 text-sm"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37"/>
          <circle cx="17.5" cy="6.5" r="1.5"/>
        </svg>
        <span class="tracking-wide">@iam_.anonymous__</span>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-on-scroll" style="transition-delay: 600ms;">
    <div class="flex flex-col items-center gap-2 text-[var(--color-text-muted)]">
      <span class="text-[10px] tracking-[0.2em] uppercase">Scroll</span>
      <div class="w-px h-6 bg-gradient-to-b from-[var(--color-accent)] to-transparent"></div>
    </div>
  </div>
</section>
